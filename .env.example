# Which Base network the frontend talks to.
# "base"        = mainnet (real ETH) — current default
# "baseSepolia" = testnet (test ETH, zero real-money risk) for safe testing first
NEXT_PUBLIC_CHAIN=base

# Address of the deployed KriptoNr1 contract (see contracts/README.md)
# v3 (claim-on-win + referral free launches) on Base mainnet, deployed 2026-07-02:
NEXT_PUBLIC_CONTRACT_ADDRESS=0x8b35250aB830Bf5190dc4220fD9Aa7a6D30A0E31

# Builder Code from base.dev — tags every transaction (ERC-8021 dataSuffix) so the
# app shows up with real metrics in the Base builder dashboard. PUBLIC value.
# Falls back to the baked-in default if unset.
NEXT_PUBLIC_BUILDER_CODE=bc_2x5t0m9v

# Base API key (base.dev) — SECRET. Server-side only, NOT prefixed with NEXT_PUBLIC.
# Optional: not needed for the game or for dashboard metrics. Keep it out of git.
# Rotate it if it ever leaks.
BASE_API_KEY=

# ---------------------------------------------------------------------------
# Base Mini App (so the app appears inside Base App)
# ---------------------------------------------------------------------------
# Public production origin, no trailing slash. If unset, Vercel's
# VERCEL_PROJECT_PRODUCTION_URL is used automatically.
NEXT_PUBLIC_URL=https://kripto-nr1.vercel.app

# Domain ownership proof for /.well-known/farcaster.json. Generate ONCE for your
# production domain with the Base manifest tool (base.dev → your app → Manifest)
# and paste the three values here / into Vercel env. Without them the manifest
# still serves but Base won't verify/publish the Mini App.
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# Optional: your Base Build wallet address — registers the app to your portfolio.
BASE_BUILDER_ADDRESS=

# ---------------------------------------------------------------------------
# DEX platform revenue knobs (all PUBLIC — they appear in txs/API calls anyway)
# ---------------------------------------------------------------------------
# LI.FI swap/bridge aggregation. Register this exact integrator string at
# https://portal.li.fi to claim the fees collected on every swap & bridge.
NEXT_PUBLIC_LIFI_INTEGRATOR=kripto-nr1
# Platform fee per swap as a fraction: 0.003 = 0.30% of the send amount.
NEXT_PUBLIC_LIFI_FEE=0.003

# Hyperliquid perps builder code. Set to YOUR wallet address — builder fees
# from every order placed in the Perps tab are paid to it (claim in the HL UI).
NEXT_PUBLIC_HL_BUILDER=
# Fee in tenths of a basis point: 25 = 2.5bps = 0.025% of notional per fill.
# Hyperliquid caps perp builder fees at 100 (= 0.1%).
NEXT_PUBLIC_HL_BUILDER_FEE=25

# Polymarket referral code appended to every Trade link (?r=...).
NEXT_PUBLIC_POLYMARKET_REF=kripto

# URL of the deployed KRIPTO Predict trading terminal
# (github.com/Topcrypt0/kripto-polymarket-app — Polymarket CLOB + builder
# attribution + Magic email login). When set, Predict "Trade" buttons open it.
NEXT_PUBLIC_POLYMARKET_APP_URL=

# Hyperliquid referral code (create yours at app.hyperliquid.xyz -> Referrals).
# Auto-attached to users without a referrer: +10% of their fees to you.
NEXT_PUBLIC_HL_REF_CODE=KRIPTO
